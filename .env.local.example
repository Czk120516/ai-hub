# DeepSeek API Key
# 申请地址：https://platform.deepseek.com/ → 创建 API Key
# 复制本文件为 .env.local 并填入你的真实 Key
DEEPSEEK_API_KEY=your_api_key_here

# 可选：自定义 DeepSeek 接口地址（默认官方地址）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 可选：默认模型（deepseek-chat 对话 / deepseek-reasoner 推理）
# DEEPSEEK_MODEL=deepseek-chat
